	affiliations = {Information Engineering University, Zhengzhou, 450001, China; Henan Key Laboratory of Information Security, National Engineering Technology Research Center of the Digital Switching System, Zhengzhou, 450001, China; National Information Technology Security Research Center, Beijing, 100085, China},
	abstract = {Penetration testing (pentesting) is a critical technique for identifying and mitigating vulnerabilities in network systems, but traditional workflows rely heavily on manual effort, leading to lengthy assessment cycles and high costs. In recent years, while automated pentesting methods based on large language models (LLMs) have gained traction, they still face challenges in complex scenarios such as multi-host networks. These include linear task decomposition, insufficient domain knowledge coverage, and weak state management capabilities, leading to compromised testing efficiency and unreliable results. To address these issues, this paper introduces PenExpert–a multi-agent autonomous pentesting framework integrating LLMs and expert systems, designed to achieve end-to-end automated testing in black-box scenarios. PenExpert designs an expert system grounded in the MITRE ATT&CK knowledge base as its semantic foundation to enhance the penetration decision-making capabilities of LLMs. By constructing a specialized penetration payload repository and leveraging retrieval-augmented generation (RAG) technology, it enables precise payload invocation. Additionally, the framework introduces a structured penetration task state management component for accurate environmental awareness, enhanced state robustness, and recoverable task execution. Experiments demonstrate that PenExpert achieves 7%–123% relative improvement in subtask completion rates across different scenarios and baselines. To the best of our knowledge, it is the first framework to demonstrate end-to-end autonomous penetration in a five-layer network scenario, validating the framework’s effectiveness and scalability in complex penetration environments. © 2026 Elsevier Ltd. All rights are reserved, including those for text and data mining, AI training, and similar technologies.},
	author_keywords = {Expert system; Large language models; Multi-agent system; Pentesting; Retrieval-augmented generation},
	keywords = {Autonomous agents; Complex networks; Data mining; Decision making; Information retrieval; Intelligent agents; Multi agent systems; Network layers; Semantics; End to end; Language model; Large language model; Multi agent; Multiagent systems (MASs); Penetration testing; Pentesting; Retrieval-augmented generation; State management; System framework; Expert systems},
	correspondence_address = {T. Zhou; Information Engineering University, Zhengzhou, 450001, China; email: aipteamzhouty@aliyun.com},
	publisher = {Elsevier Ltd},

	url = {https://www.scopus.com/pages/publications/105040060954?origin=resultslist},
	affiliations = {Key Lab of Structures Dynamic Behavior and Control of the Ministry of Education, Harbin Institute of Technology, Harbin, 150094, China; Key Lab of Smart Prevention and Mitigation of Civil Engineering Disaster of the Ministry of Industry and Information Technology, Harbin Institute of Technology, Harbin, 150094, China; Institute of Defense Engineering, AMS, PLA, Beijing, 100850, China},
	abstract = {Modern geopolitical conflicts increasingly target interdependent critical infrastructures, where localized damage can trigger cascading failures, leading to widespread disruption of essential public services. Traditional intelligence safety assessment frameworks struggle to process the dynamic, unstructured data streams from conflict environments. To bridge this gap, this paper introduces a novel probabilistic framework for dynamic cascading failure analysis of Critical Infrastructure (CI) under attacks by integrating Large Language Model (LLM) and Knowledge Graph (KG). Our novel dual-graph architecture first employs an LLM to automatically construct a Dynamic Battlefield Event Knowledge Graph (BEKG) from real-time Open-Source Intelligence (OSINT), capturing tactical events as they unfold. This dynamic event layer then serves as evidence for a probabilistic inference process on a static Infrastructure Service Dependency Knowledge Graph (ISDKG), which is modeled as a Bayesian Network (BN). This integration enables the simulation of the propagation of cascading failures, translating initial physical damage into a quantifiable risk assessment of widespread service disruptions. Validated through a case study on Ukraine's infrastructure, our system demonstrates high fidelity in automated knowledge construction, provides novel insights into cascading impact analysis, and offers a powerful decision-support tool for assessing the systemic vulnerability and resilience of complex infrastructure networks in conflict zones. © 2026 Elsevier Ltd.},
	author_keywords = {Cascading failure; Critical infrastructure; Knowledge graph; Large language model; Service disruption},
	keywords = {Bayesian networks; Complex networks; Computer hardware description languages; Damage detection; Decision support systems; Failure (mechanical); Failure analysis; Inference engines; Knowledge graph; Network security; Outages; Public works; Risk assessment; Safety engineering; Cascading failure analysis; Cascading failures; Conflict zones; Graph framework; Knowledge graphs; Language model; Large language model; Localized damage; Model-driven; Service disruptions; Critical infrastructures},
